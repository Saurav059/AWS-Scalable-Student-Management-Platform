# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=replace-with-a-secure-secret-key-for-session-signing
JWT_SECRET_KEY=replace-with-a-secure-jwt-key

# Database Connection (MySQL or SQLite fallback)
# Production MySQL URL format: mysql+pymysql://username:password@rds-host:3306/dbname
DATABASE_URL=sqlite:///student_platform.db

# Storage Service Configuration
# Choices: local, s3
STORAGE_TYPE=local
UPLOAD_FOLDER=app/static/uploads

# AWS Credentials (Required if STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name
